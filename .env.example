# KPM one-command local deployment template.
# Copy this file to .env before running Docker Compose.

KPM_DB_NAME=kpm
KPM_DB_USER=kpm
KPM_DB_PASSWORD=kpm_dev_password
KPM_DB_PORT=5432

KPM_VALKEY_PORT=6379
KPM_NACOS_PORT=8848
KPM_NACOS_CONSOLE_PORT=8849
KPM_NACOS_GRPC_PORT=9848
KPM_NACOS_ADDR=nacos:8848
KPM_NACOS_ENABLED=true
KPM_NACOS_CONFIG_ENABLED=true
KPM_NACOS_NAMESPACE=public
KPM_NACOS_CONFIG_GROUP=DEFAULT_GROUP
KPM_NACOS_JVM_XMS=128m
KPM_NACOS_JVM_XMX=512m
KPM_NACOS_JVM_XMN=64m

KPM_GATEWAY_PORT=8080
KPM_IAM_PORT=8101
KPM_RESOURCE_PORT=8102
KPM_PROJECT_PORT=8103
KPM_CUSTOMER_PORT=8104
KPM_TASK_PORT=8105
KPM_ORDER_PORT=8106
KPM_FILE_PORT=8107
KPM_ANALYTICS_PORT=8108
KPM_INTEGRATION_PORT=8109
KPM_NOTIFICATION_PORT=8110
KPM_FRONTEND_PORT=4173

KPM_AUTH_ENABLED=true
KPM_RBAC_ENABLED=true
KPM_AUTH_TOKEN_SECRET=kpm-local-dev-secret-change-me
KPM_NOTIFICATION_REFRESH_INTERVAL_SECONDS=120
KPM_NOTIFICATION_PROCESSOR_INTERVAL_MS=15000
KPM_NOTIFICATION_MAIL_ENABLED=false
KPM_NOTIFICATION_MAIL_FROM=noreply@kozen.example

# OSS is managed by Nacos for services. Keep secrets out of git.
# kpm-file-service.yaml should define kpm.oss.enabled/access-key-id/access-key-secret/bucket/endpoint/root-prefix.
# For a fresh machine, fill the commented values below before the first compose startup;
# the nacos-config-publisher service will publish them into Nacos and back them up under .local/.
KPM_OSS_ENABLED=false
KPM_OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
KPM_OSS_BUCKET=xc-kozen-sh-fw
KPM_OSS_ROOT_PREFIX=KPM/
# KPM_OSS_ACCESS_KEY_ID=
# KPM_OSS_ACCESS_KEY_SECRET=
KPM_OSS_DOWNLOAD_URL_EXPIRE_SECONDS=900
KPM_UPLOAD_MAX_FILE_SIZE=500MB
KPM_UPLOAD_MAX_REQUEST_SIZE=520MB
